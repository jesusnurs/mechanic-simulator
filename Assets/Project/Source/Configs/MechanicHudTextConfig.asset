  taskHeader: "\u042D\u0442\u0430\u043F 1: \u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E \u043C\u0435\u0441\u0442\u0430"
  taskText: "\u041E\u0442\u043A\u0440\u0443\u0442\u0438\u0442\u0435 5 \u0431\u043E\u043B\u0442\u043E\u0432 \u043A\u043E\u043B\u0435\u0441\u0430"
  progressText: "\u041F\u0440\u043E\u0433\u0440\u0435\u0441\u0441: 0/5"
  welcomeTitle: "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0443\u044E"
  welcomeText: "\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435:\nWASD / \u0441\u0442\u0440\u0435\u043B\u043A\u0438 - \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\n\u041C\u044B\u0448\u044C - \u043E\u0441\u043C\u043E\u0442\u0440\nShift - \u0443\u0441\u043A\u043E\u0440\u0438\u0442\u044C\u0441\u044F\n\u041B\u041A\u041C / E - \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C\n1-9 - \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\nF - \u0443\u0431\u0440\u0430\u0442\u044C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\nEsc - \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C \u043A\u0443\u0440\u0441\u043E\u0440"
  welcomeCloseText: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 Enter / Space / E / \u041B\u041A\u041C, \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0447\u0430\u0442\u044C"
